{
  "name": "koala",
  "version": "1.0.14",
  "main": "electron/main.js",
  "desktopAppUrl": "http://koala.simplifysystem.com.br/",
  "author": {
    "name": "Simplify Soluções",
    "email": "suporte@simplifysystem.com.br"
  },
  "scripts": {
    "ng": "ng",
    "start": "npm run start:web",
    "start:web": "concurrently \"npm run start:web:build\" \"npm run start:web:server\"",
    "start:web:build": "ng build --configuration development --watch",
    "start:web:server": "node .\\scripts\\dev-server.js",
    "start:electron": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Remove-Item Env:ELECTRON_RUN_AS_NODE -ErrorAction SilentlyContinue; & .\\node_modules\\electron\\dist\\electron.exe .\"",
    "start:electron:remote": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Remove-Item Env:ELECTRON_RUN_AS_NODE -ErrorAction SilentlyContinue; $env:ELECTRON_START_URL='https://SEU_FRONTEND_AQUI'; & .\\node_modules\\electron\\dist\\electron.exe .\"",
    "start:desktop:dev": "concurrently \"npm run start:web\" \"wait-on http://127.0.0.1:4301 && npm run start:electron\"",
    "start:desktop": "npm run build:desktop:dir && .\\dist-electron\\win-unpacked\\Koala.exe",
    "build": "ng build",
    "build:web": "ng build",
    "build:web:prod": "ng build --configuration production",
    "publish:web": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (-not $env:KOALA_WEB_PUBLISH_DIR) { throw 'Defina KOALA_WEB_PUBLISH_DIR com a pasta de publicacao da web.' }; & .\\scripts\\publish-web.ps1 -PublishDir $env:KOALA_WEB_PUBLISH_DIR -Clean\"",
    "build:desktop:dir": "npx electron-builder --config electron-builder.config.js --dir",
    "build:desktop:fresh": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$out = 'dist-electron-builds/' + (Get-Date -Format 'yyyyMMdd-HHmmss'); $env:ELECTRON_BUILDER_OUTPUT = $out; npx electron-builder --config electron-builder.config.js\"",
    "build:desktop:linux": "npx electron-builder --config electron-builder.config.js --linux AppImage",
    "build:desktop:github": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (-not $env:GH_OWNER) { throw 'Defina GH_OWNER para publicar no GitHub.' }; if (-not $env:GH_REPO) { throw 'Defina GH_REPO para publicar no GitHub.' }; if (-not ($env:GH_TOKEN -or $env:GITHUB_TOKEN)) { throw 'Defina GH_TOKEN ou GITHUB_TOKEN para publicar no GitHub.' }; $out = 'dist-electron-builds/' + (Get-Date -Format 'yyyyMMdd-HHmmss'); $env:ELECTRON_BUILDER_OUTPUT = $out; npx electron-builder --config electron-builder.config.js --publish always\"",
    "build:desktop": "npm run build:desktop:fresh",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (-not $env:KOALA_DESKTOP_URL) { throw 'Defina KOALA_DESKTOP_URL com a URL publicada do frontend.' }; & .\\scripts\\release.ps1 -DesktopUrl $env:KOALA_DESKTOP_URL\"",
    "release:web": "npm run build:web:prod",
    "release:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (-not $env:KOALA_DESKTOP_URL) { throw 'Defina KOALA_DESKTOP_URL com a URL publicada do frontend.' }; & .\\scripts\\release.ps1 -DesktopUrl $env:KOALA_DESKTOP_URL\"",
    "release:desktop:github": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& .\\scripts\\release-github-tag.ps1\"",
    "release:desktop:local": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& .\\scripts\\release-local.ps1\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "17.3.12",
    "@angular/common": "17.3.12",
    "@angular/compiler": "17.3.12",
    "@angular/core": "17.3.12",
    "@angular/forms": "17.3.12",
    "@angular/platform-browser": "17.3.12",
    "@angular/platform-browser-dynamic": "17.3.12",
    "@angular/router": "17.3.12",
    "@po-ui/ng-components": "^17.26.22",
    "@po-ui/ng-schematics": "^17.26.22",
    "@po-ui/ng-templates": "^17.26.22",
    "@po-ui/style": "16.12.0",
    "@serialport/parser-readline": "^13.0.0",
    "@totvs/common-assets": "^1.1.1",
    "@totvs/po-theme": "^15.15.0",
    "electron-updater": "^6.8.3",
    "font-awesome": "4.7.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.4",
    "lint-staged": "15.2.0",
    "ng2-pdf-viewer": "^9.1.5",
    "ngx-extended-pdf-viewer": "^25.6.4",
    "prettier": "3.2.4",
    "rxjs": "^7.8.1",
    "serialport": "^13.0.0",
    "socket.io": "^4.7.1",
    "socket.io-client": "^4.7.1",
    "tslib": "^2.8.1",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "17.3.17",
    "@angular-eslint/builder": "16.3.1",
    "@angular-eslint/eslint-plugin": "^17.5.3",
    "@angular-eslint/eslint-plugin-template": "^17.5.3",
    "@angular-eslint/schematics": "^17.5.3",
    "@angular-eslint/template-parser": "^17.5.3",
    "@angular/cli": "17.3.17",
    "@angular/compiler-cli": "17.3.12",
    "@types/jasmine": "~4.3.0",
    "@types/node": "^20.8.2",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "concurrently": "^9.2.1",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "eslint": "8.51.0",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "typescript": "~5.4.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "br.com.koala",
    "productName": "Koala",
    "npmRebuild": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "src/assets/Simplify.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
